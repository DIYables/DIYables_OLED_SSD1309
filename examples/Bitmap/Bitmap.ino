#define DIYABLES_BITMAP_WIDTH  128
#define DIYABLES_BITMAP_HEIGHT  57

void setup() {
  Serial.begin(9600);

  if (!display.begin(SSD1309_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("SSD1309 allocation failed"));
    for (;;)
      ;
  }

  display.clearDisplay();
  display.display();
}

void showbitmapHeart() {
  display.clearDisplay();

  int16_t x = (display.width() - 16) / 2;
  int16_t y = 4;
  display.drawBitmap(x, y, bitmapHeart, 16, 16, SSD1309_PIXEL_ON);

  // Add a label below
  display.setTextSize(1);
  display.setTextColor(SSD1309_PIXEL_ON);
  display.setCursor(20, 30);
  display.println(F("DIYables OLED"));
  display.setCursor(16, 44);
  display.println(F("Bitmap Example"));

  display.display();
}

void showDIYablesBitmap() {
  display.clearDisplay();

  int16_t x = 0;
  int16_t y = (display.height() - DIYABLES_BITMAP_HEIGHT) / 2;
  display.drawBitmap(x, y, bitmapDIYables, DIYABLES_BITMAP_WIDTH, DIYABLES_BITMAP_HEIGHT, SSD1309_PIXEL_ON);

  display.display();
}

void loop() {
  // Alternate between the two bitmaps
  showbitmapHeart();
  delay(3000);

  showDIYablesBitmap();
  delay(3000);
}
